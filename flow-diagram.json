  "flows": [
    {
      "id": "flow_resign_to_spot",
      "role": "trainer",
      "name": "退職→SPOT登録フロー",
      "description": "在籍社員が退職意向を出し、HR処理後にSPOTトレーナーとして登録される",
      "priority": "critical",
      "steps": [
        { "step": 1, "page": "t_home", "action": "退職意向カードをクリック", "element": "link_resignation", "expected_result": "退職フォーム表示" },
        { "step": 2, "page": "t_resignation", "action": "退職意向を入力・提出", "element": "form_resignation", "expected_result": "提出完了→ホームに戻る" },
        { "step": 3, "page": "hr_resignations", "action": "HR が受理→退職完了処理", "element": "btn_complete", "expected_result": "alumni_trainers作成・role変更" },
        { "step": 4, "page": "t_home", "action": "SPOT登録カードが表示", "element": "link_spot_setup", "expected_result": "spot-setupへ誘導" },
        { "step": 5, "page": "t_spot_setup", "action": "エリア・時間帯を選択してSPOT開始", "element": "form_spot_setup", "expected_result": "active→シフト検索可能" }
      ]
    },
    {
      "id": "flow_shift_apply",
      "role": "trainer",
      "name": "シフト応募フロー",
      "description": "トレーナーがシフトを検索・応募する",
      "priority": "critical",
      "steps": [
        { "step": 1, "page": "t_home", "action": "シフトを探すリンクをタップ", "element": "link_shifts", "expected_result": "シフト検索画面" },
        { "step": 2, "page": "t_shifts", "action": "シフトカードをタップ", "element": "link_shift_detail", "expected_result": "シフト詳細画面" },
        { "step": 3, "page": "t_shift_detail", "action": "応募するボタン", "element": "btn_apply", "expected_result": "応募確認画面" },
        { "step": 4, "page": "t_apply", "action": "応募確定", "element": "btn_confirm_apply", "expected_result": "応募完了→マイシフト" }
      ]
    },
    {
      "id": "flow_clock_in_out",
      "role": "trainer",
      "name": "出退勤打刻フロー",
      "description": "QRコードによる出退勤記録",
      "priority": "critical",
      "steps": [
        { "step": 1, "page": "t_home", "action": "打刻ボタンタップ", "element": "btn_clock", "expected_result": "打刻画面" },
        { "step": 2, "page": "t_clock", "action": "QR表示→店舗スキャン", "element": "btn_show_qr", "expected_result": "出勤記録" },
        { "step": 3, "page": "t_clock", "action": "退勤QR表示→店舗スキャン", "element": "btn_show_qr", "expected_result": "退勤記録+勤務時間計算" }
      ]
    },
    {
      "id": "flow_store_shift_create",
      "role": "store_manager",
      "name": "シフト作成→応募管理フロー",
      "description": "店舗がシフトを作成し、応募を管理する",
      "priority": "critical",
      "steps": [
        { "step": 1, "page": "s_dashboard", "action": "シフト作成へ遷移", "element": "btn_create_shift", "expected_result": "シフト作成画面" },
        { "step": 2, "page": "s_shifts", "action": "シフト情報入力・作成", "element": "form_shift", "expected_result": "シフト作成→HR承認待ち" },
        { "step": 3, "page": "s_applications", "action": "応募者を承認/却下", "element": "btn_approve", "expected_result": "承認→トレーナーに通知" }
      ]
    },
    {
      "id": "flow_hr_matching",
      "role": "hr",
      "name": "HRマッチング管理フロー",
      "description": "HR がシフト承認・オファー送信・退職処理を行う",
      "priority": "critical",
      "steps": [
        { "step": 1, "page": "hr_dashboard", "action": "シフト承認", "element": "btn_approve_shift", "expected_result": "公開→トレーナー検索可能" },
        { "step": 2, "page": "hr_resignations", "action": "退職完了処理", "element": "btn_complete", "expected_result": "SPOT自動登録" }
      ]
    }
  ],
  "cross_role_interactions": [
    {
      "id": "xrole_resign",
      "name": "退職→SPOT登録の連携",
      "description": "トレーナーが退職意向提出→HRが退職完了処理→トレーナーにSPOT登録案内",
      "initiator_role": "trainer",
      "affected_roles": ["hr"],
      "flow_steps": [
        { "role": "trainer", "action": "退職意向提出", "flow_ref": "flow_resign_to_spot" },
        { "role": "hr", "action": "受理→退職完了→alumni作成", "flow_ref": "flow_hr_matching" }
      ]
    },
    {
      "id": "xrole_shift_match",
      "name": "シフトマッチング連携",
      "description": "店舗がシフト作成→HR承認→トレーナー応募→店舗承認→勤務",
      "initiator_role": "store_manager",
      "affected_roles": ["hr", "trainer"],
      "flow_steps": [
        { "role": "store_manager", "action": "シフト作成", "flow_ref": "flow_store_shift_create" },
        { "role": "hr", "action": "シフト承認", "flow_ref": "flow_hr_matching" },
        { "role": "trainer", "action": "応募→打刻", "flow_ref": "flow_shift_apply" }
      ]
    }
  ],
  "test_matrix": {
    "description": "ローンチ前最終レビュー用テストマトリクス",
    "agents": [
      { "agent_id": "agent_trainer", "role": "trainer", "assigned_flows": ["flow_resign_to_spot", "flow_shift_apply", "flow_clock_in_out"], "assigned_pages": ["t_home", "t_shifts", "t_my_shifts", "t_clock", "t_earnings", "t_profile", "t_spot_setup"], "focus": "トレーナー全導線・キャンセルフロー・LINE連携" },
      { "agent_id": "agent_store", "role": "store_manager", "assigned_flows": ["flow_store_shift_create"], "assigned_pages": ["s_dashboard", "s_shifts", "s_applications", "s_attendance"], "focus": "店舗シフト管理・モバイルナビ" },
      { "agent_id": "agent_hr", "role": "hr", "assigned_flows": ["flow_hr_matching"], "assigned_pages": ["hr_dashboard", "hr_resignations", "hr_rates"], "focus": "HR退職処理・マッチング管理" }
    ],
    "cross_role_agent": { "agent_id": "agent_cross", "focus": "退職→SPOT登録連携、シフトマッチング連携", "assigned_interactions": ["xrole_resign", "xrole_shift_match"] }
  },
  "playwright_config": {
    "base_url": "http://localhost:3000",
    "output_dir": "tests/e2e",
    "timeouts": { "navigation": 10000, "action": 5000, "assertion": 5000 },
    "responsive_breakpoints": [375, 768, 1280]
  }
}
